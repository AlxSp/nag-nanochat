# Shared settings for the paired 8xH100/H200 64x640 experiments.
# Source this file from the repo root.

export NANOCHAT_BASE_DIR="${NANOCHAT_BASE_DIR:-/workspace/nanochat}"
export HF_HUB_ENABLE_HF_TRANSFER="${HF_HUB_ENABLE_HF_TRANSFER:-1}"
export HF_HUB_DISABLE_PROGRESS_BARS="${HF_HUB_DISABLE_PROGRESS_BARS:-1}"
export OMP_NUM_THREADS="${OMP_NUM_THREADS:-1}"

export NPROC_PER_NODE="${NPROC_PER_NODE:-8}"
export DEPTH="${DEPTH:-64}"
export MODEL_DIM="${MODEL_DIM:-640}"
export HEAD_DIM="${HEAD_DIM:-128}"
export WINDOW_PATTERN="${WINDOW_PATTERN:-L}"
export TARGET_FLOPS="${TARGET_FLOPS:-3e19}"
export TARGET_PARAM_DATA_RATIO="${TARGET_PARAM_DATA_RATIO:--1}"

# The earlier H100 run fit with device batch size 16. The NaN trigger was the
# NAG modulator pow backward at s=0, not an OOM or confirmed microbatch issue.
export DEVICE_BATCH_SIZE="${DEVICE_BATCH_SIZE:-16}"
export TOTAL_BATCH_SIZE="${TOTAL_BATCH_SIZE:--1}"

export EVAL_EVERY="${EVAL_EVERY:-250}"
export SAVE_EVERY="${SAVE_EVERY:-100}"
export SAMPLE_EVERY="${SAMPLE_EVERY:--1}"
export CORE_METRIC_EVERY="${CORE_METRIC_EVERY:-999999}"

# Conservative next-run LR defaults after the NaN run.
export MATRIX_LR="${MATRIX_LR:-0.012}"
export EMBEDDING_LR="${EMBEDDING_LR:-0.18}"
export UNEMBEDDING_LR="${UNEMBEDDING_LR:-0.006}"
export SCALAR_LR="${SCALAR_LR:-0.5}"
